<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Roman Yosi Official Artist</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    background:#000;
    color:white;
    font-family:Arial,sans-serif;
}

/* HERO */

.hero{
    height:100vh;
    background:
    linear-gradient(to bottom,rgba(0,0,0,0.4),#000),
    url('https://raw.githubusercontent.com/Roman-Yosi/Poto-roman-yosi/main/ChatGPT%20Image%2011%20Mei%202026%2C%2020.58.16.png');
    background-size:cover;
    background-position:center;
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
    padding:20px;
}

.hero-content h1{
    font-size:70px;
    margin-bottom:10px;
}

.verify{
    color:#1DA1F2;
    font-size:40px;
}

.hero-content p{
    color:#ccc;
    font-size:20px;
    margin-bottom:25px;
}

.hero-content a{
    display:inline-block;
    padding:14px 30px;
    background:#1DB954;
    color:white;
    text-decoration:none;
    border-radius:40px;
    transition:0.3s;
}

.hero-content a:hover{
    background:#18a64d;
}

/* PROFILE */

.profile{
    padding:60px 20px;
    max-width:1000px;
    margin:auto;
    display:flex;
    gap:40px;
    align-items:center;
    flex-wrap:wrap;
}

.profile img{
    width:220px;
    height:220px;
    object-fit:cover;
    border-radius:50%;
    border:5px solid #1DB954;
}

.bio{
    flex:1;
}

.bio h2{
    margin-bottom:20px;
    color:#1DB954;
}

.bio p{
    line-height:1.8;
    color:#ccc;
}

/* RELEASE */

.release{
    padding:60px 20px;
}

.release h2{
    text-align:center;
    margin-bottom:40px;
    color:#1DB954;
}

.grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:25px;
}

.card{
    background:#111;
    border-radius:20px;
    overflow:hidden;
    transition:0.3s;
}

.card:hover{
    transform:translateY(-5px);
}

.card img{
    width:100%;
    height:250px;
    object-fit:cover;
}

.card-content{
    padding:20px;
}

.card-content h3{
    margin-bottom:10px;
}

.status{
    color:#1DB954;
    font-weight:bold;
}

/* SOCIAL */

.social{
    text-align:center;
    padding:60px 20px;
}

.social h2{
    margin-bottom:25px;
    color:#1DB954;
}

.social a{
    display:block;
    margin:15px;
    color:#1DB954;
    text-decoration:none;
    font-size:18px;
}

/* FOOTER */

footer{
    background:#050505;
    text-align:center;
    padding:30px;
    color:#777;
}

</style>
</head>

